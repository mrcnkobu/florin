{
  "name": "florin",
  "version": "0.1.0",
  "description": "A text-first Obsidian investment keeper.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "format": "prettier --write .",
    "check": "npm run lint && npm run test && npm run build",
    "deploy:test": "node scripts/deploy.mjs test",
    "deploy:prod": "node scripts/deploy.mjs prod"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "investments",
    "portfolio"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^22.14.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.2",
    "eslint": "^9.24.0",
    "obsidian": "^1.8.7",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "decimal.js": "^10.5.0"
  }
}
